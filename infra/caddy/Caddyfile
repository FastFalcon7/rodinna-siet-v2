# ── Rodinná Sieť v2 — Caddy ──────────────────────────────────────────────────
# Interná appka za zdieľanou NAS-wide edge vrstvou — TLS a doménové routovanie
# (Synology DDNS, Let's Encrypt) rieši edge Caddy mimo tohto repa, viď
# docs/SYNOLOGY_DOMAIN_ACTIVATION.md. Tento kontajner len servíruje web
# statiku a proxuje /api, /ws na čistom HTTP v internej Docker sieti.

:80 {
	encode zstd gzip

	# Bezpečnostné hlavičky (ARCHITECTURE_V2.md §9)
	header {
		-Server
		Referrer-Policy strict-origin-when-cross-origin
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}

	# handle bloky sa vyhodnocujú zhora nadol a vzájomne sa vylučujú — bez nich
	# by Caddyfile adapter zoradil try_files/file_server pred reverse_proxy podľa
	# vlastného pevného poradia direktív a @api matcher by sa nikdy nedostal ku slovu.
	handle /api/* {
		reverse_proxy api:3000
	}
	handle /ws {
		reverse_proxy api:3000
	}

	# SPA statika
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
