# ── Rodinná Sieť v2 — Caddy ──────────────────────────────────────────────────
# Interná appka za zdieľanou NAS-wide edge vrstvou — TLS a doménové routovanie
# (Synology DDNS, Let's Encrypt) rieši edge Caddy mimo tohto repa, viď
# docs/SYNOLOGY_DOMAIN_ACTIVATION.md. Tento kontajner len servíruje web
# statiku a proxuje /api, /ws na čistom HTTP v internej Docker sieti.

:80 {
	encode zstd gzip

	# API + WebSocket → api kontajner
	@api path /api/* /ws
	reverse_proxy @api api:3000

	# SPA statika
	root * /srv/web
	try_files {path} /index.html
	file_server

	# Bezpečnostné hlavičky (ARCHITECTURE_V2.md §9)
	header {
		-Server
		Referrer-Policy strict-origin-when-cross-origin
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}
}
