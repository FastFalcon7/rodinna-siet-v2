# ─────────────────────────────────────────────────────────────
# Rodinná Sieť v2 — príklad konfigurácie
# Skopíruj do `.env` a uprav. `.env` je v .gitignore.
# ─────────────────────────────────────────────────────────────

# Doména appky. Lokálne "localhost", na NAS napr. rodinna-tvojmeno.synology.me.
# Používa ju zdieľaný NAS-wide edge Caddy (mimo tohto repa) na TLS + hostname
# routovanie — viď docs/SYNOLOGY_DOMAIN_ACTIVATION.md. PUBLIC_WEB_ORIGIN
# nižšie musí byť https://<DOMAIN> v produkcii.
DOMAIN=localhost

# Node/Bun prostredie: development | production
NODE_ENV=development

# ── API ──────────────────────────────────────────────────────
API_PORT=3000
# Port na hostiteľovi (len pre dev override) — zmeň, ak 3000 už niečo používa
API_HOST_PORT=3000
# Port na hostiteľovi pre Vite dev server — zmeň, ak 5173 už niečo používa
WEB_HOST_PORT=5173
# Verejný pôvod webu (pre CORS). Pri dev cez Caddy = https://localhost
PUBLIC_WEB_ORIGIN=http://localhost:5173

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=rodinna
POSTGRES_PASSWORD=zmen_ma_v_produkcii
POSTGRES_DB=rodinna
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Port na hostiteľovi (len pre dev override) — zmeň, ak 5432 už niečo používa
POSTGRES_HOST_PORT=5433
# Drizzle/aplikácia používa túto URL (povinná od T2)
DATABASE_URL=postgres://rodinna:zmen_ma_v_produkcii@postgres:5432/rodinna

# ── Auth ─────────────────────────────────────────────────────
# Životnosť session v dňoch (sliding — predĺži sa pri aktivite)
SESSION_TTL_DAYS=30

# ── Media (upload) ───────────────────────────────────────────
# Kam sa na hostiteľovi ukladajú nahrané súbory (mapuje sa na /data/media v kontajneri).
# Na NAS odporúčam napr. /volume1/rodinna/media. Lokálne defaultne ./media.
MEDIA_HOST_PATH=./media
# Max veľkosť nahrávaného obrázka v MB.
MAX_IMAGE_MB=50

# ── Web (Vite, build-time) ───────────────────────────────────
# URL kam web volá API. Pri dev cez Caddy ostáva /api (rovnaký origin).
VITE_API_URL=/api

# ── Phase 2 (zatiaľ nepoužité) ───────────────────────────────
# LLM_BASE_URL=http://ollama:11434/v1
# LLM_MODEL=llama3.2:3b-instruct-q4_K_M
